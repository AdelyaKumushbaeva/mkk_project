<Page x:Class="WpfApp_ИСиТ.AddEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp_ИСиТ"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="110"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ФИО Клиента:" Foreground="green" Margin="10" VerticalAlignment="Center"></TextBlock>
        <TextBlock Text="Сумма займа:" Foreground="green" Grid.Row="1" Margin="10" VerticalAlignment="Center"></TextBlock>
        <TextBlock Text="Срок (дней):" Foreground="green" Grid.Row="2" Margin="10" VerticalAlignment="Center"></TextBlock>
        <TextBlock Text="Ставка (%):" Foreground="green" Grid.Row="3" Margin="10" VerticalAlignment="Center"></TextBlock>

        <TextBox Text="{Binding mountain_name}" MaxLength="100" Grid.Column="1" Margin="5" VerticalAlignment="Center"></TextBox>
        <TextBox Text="{Binding height}" Grid.Column="1" Grid.Row="1" Width="175" HorizontalAlignment="Left" Margin="5" VerticalAlignment="Center"></TextBox>
        <TextBox Text="{Binding country}" Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center"></TextBox>
        <TextBox Text="{Binding region}" Grid.Column="1" Grid.Row="3" Margin="5" VerticalAlignment="Center"></TextBox>

        <Button Content="Сохранить" Grid.ColumnSpan="2" Grid.Row="4" Name="BtnSave" Click="BtnSave_Click" 
            HorizontalAlignment="Center" Width="150" Height="30"></Button>
    </Grid>
</Page>